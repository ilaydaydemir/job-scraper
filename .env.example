# Adzuna API (free) — https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# Reed UK API (free) — https://www.reed.co.uk/developers/jobseeker
REED_API_KEY=your_reed_key_here

# Backend URL — job application app (push scraped jobs automatically)
BACKEND_URL=http://localhost:8000

# Email notifications (optional — Gmail App Password)
NOTIFY_EMAIL_FROM=your.email@gmail.com
NOTIFY_EMAIL_TO=ilayda@aicro.co
NOTIFY_EMAIL_PASS=your_gmail_app_password
